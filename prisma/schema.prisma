generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int @id @default(autoincrement())
  pseudo    String? @unique
  avatarUrl String?
  email     String?  @unique
  password  String?
  invitationsFrom Invitation[] @relation("invitationsFrom")
  invitationsTo Invitation[] @relation("invitationsTo")
  gamesWon        GameMatch[]  @relation("gameMatchWinner")
  gamesLost       GameMatch[]  @relation("gameMatchLoser")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invitation {
  id Int @id @default(autoincrement())
  fromUser User @relation("invitationsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId Int
  toUser User @relation("invitationsTo", fields: [toId], references: [id], onDelete: Cascade)
  toId Int
  game String
}

model GameMatch {
  id       Int      @id @default(autoincrement())
  game     String
  date     DateTime @default(now())
  draw     Boolean  @default(false)
  winner   User?    @relation("gameMatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  winnerId Int?
  loser    User?    @relation("gameMatchLoser", fields: [loserId], references: [id], onDelete: SetNull)
  loserId  Int?
}